# === 必填（核心功能） ===
# 以下留空可照樣跑掃描看板，無需任何帳號

# === 選填（AI 解盤功能） ===
# analyst.py 四師解盤需要 OpenAI 相容 API key
# 推薦用 OpenRouter 免費模型（不花錢）
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENAI_API_KEY=sk-or-xxxxx

# === 選填（推播通知） ===
# 填入任意字串作為 ntfy.sh topic，手機安裝 ntfy app 即可收到訊號推播
NTFY_TOPIC=

# === 選填（財報資料）===
# FinMind 免費方案可申請 token（finmindtrade.com），不填則基本面用 yfinance
FINMIND_TOKEN=
